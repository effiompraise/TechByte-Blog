<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechByte Blog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">TechByte Blog</a>
        <a class="btn btn-outline-light btn-sm" href="/admin">Admin Portal</a>
    </div>
</nav>

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2 class="mb-4">Latest Posts</h2>
            
            <% posts.forEach(post => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h4 class="card-title"><%= post.title %></h4>
                        <h6 class="text-muted"><%= new Date(post.created_at).toDateString() %></h6>
                        <p class="card-text"><%= post.content.substring(0, 100) %>...</p>
                        <a href="/post/<%= post.post_id %>" class="btn btn-primary btn-sm">Read More</a>
                    </div>
                </div>
            <% }) %>

            <% if (posts.length === 0) { %>
                <p>No posts yet. Go to the Admin Portal to create one!</p>
            <% } %>
        </div>
    </div>
</div>

</body>
</html>