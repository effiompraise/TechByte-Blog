<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - TechByte</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">TechByte Blog</a>
        <a class="btn btn-outline-light btn-sm" href="/admin">Admin Portal</a>
    </div>
</nav>

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h1 class="card-title"><%= post.title %></h1>
                    <p class="text-muted">Published on <%= new Date(post.created_at).toDateString() %></p>
                    <hr>
                    <div class="card-text" style="white-space: pre-wrap;"><%= post.content %></div>
                </div>
            </div>

            <h4>Comments</h4>
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <ul id="commentList" class="list-group list-group-flush mb-3">
                        <% if (comments.length === 0) { %>
                            <li class="list-group-item text-muted" id="noCommentsMsg">No comments yet. Be the first!</li>
                        <% } else { %>
                            <% comments.forEach(comment => { %>
                                <li class="list-group-item">
                                    <strong><%= comment.author_name %></strong> 
                                    <span class="text-muted small"> - <%= new Date(comment.created_at).toLocaleString() %></span>
                                    <p class="mb-0 mt-1"><%= comment.comment_text %></p>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>

                    <h5 class="mt-4">Leave a Comment</h5>
                    <form id="commentForm">
                        <input type="hidden" id="postId" value="<%= post.post_id %>">
                        
                        <div class="mb-3">
                            <label for="authorName" class="form-label">Name</label>
                            <input type="text" class="form-control" id="authorName" required>
                        </div>
                        <div class="mb-3">
                            <label for="commentText" class="form-label">Comment</label>
                            <textarea class="form-control" id="commentText" rows="3" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Submit Comment</button>
                    </form>
                </div>
            </div>
            
            <a href="/" class="btn btn-secondary mb-5">&larr; Back to Home</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('commentForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const postId = document.getElementById('postId').value;
        const authorName = document.getElementById('authorName').value;
        const commentText = document.getElementById('commentText').value;

        fetch('/api/comments', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                post_id: postId,
                author_name: authorName,
                comment_text: commentText
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const noCommentsMsg = document.getElementById('noCommentsMsg');
                if (noCommentsMsg) noCommentsMsg.remove();

                const newCommentLi = document.createElement('li');
                newCommentLi.className = 'list-group-item bg-light';
                newCommentLi.innerHTML = `
                    <strong>${data.comment.author_name}</strong> 
                    <span class="text-muted small"> - Just now</span>
                    <p class="mb-0 mt-1">${data.comment.comment_text}</p>
                `;

                document.getElementById('commentList').appendChild(newCommentLi);
                document.getElementById('authorName').value = '';
                document.getElementById('commentText').value = '';
            } else {
                alert('Error submitting comment.');
            }
        })
        .catch(error => console.error('Error:', error));
    });
</script>

</body>
</html>